#!/bin/sh
"""
Ariana - интеллектуальный ассистент
"""

__version__ = "0.1.0"

cp README.md extensions/vscode/README.md
cp README.md cli/ariana-py/README.md
cp README.md cli/ariana-npm/README.md
cp README.md ../dedale-ariana/README.md
git add extensions/vscode/README.md cli/ariana-py/README.md cli/ariana-npm/README.md

[tool.poetry]
name = "ariana"
version = "0.1.0"
description = "Интеллектуальный ассистент Ariana"
authors = ["Your Name <your.email@example.com>"]

[tool.poetry.dependencies]
python = "^3.9"
ariana-core = { path = "../ariana-core" }

[tool.poetry.dev-dependencies]
pytest = "^7.4.0"
black = "^23.3.0"
mypy = "^1.4.1"
flake8 = "^6.0.0"

[build-system]
requires = ["poetry-core>=1.0.0"]
build-backend = "poetry.core.masonry.api"

.venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
.mypy_cache/
.vscode/
dist/
build/
*.egg-info/

{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.linting.enabled": true,
    "python.linting.flake8Enabled": true,
    "python.formatting.provider": "black",
    "editor.formatOnSave": true,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.nosetestsEnabled": false,
    "python.testing.pytestArgs": [
        "tests"
    ]
}